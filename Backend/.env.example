# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Cloudinary Configuration (Get from https://cloudinary.com/console)
CLOUDINARY_API=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_secret_key
CLOUD_NAME=your_cloudinary_cloud_name

# JWT Configuration (Generate strong random strings)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-in-production
ENCRYPTION_KEY=your-32-character-encryption-key-for-aes256

# Database URLs (MongoDB Atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?options
MONGODB_URI_AUTH=mongodb+srv://username:password@cluster.mongodb.net/chat-auth?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI_USER=mongodb+srv://username:password@cluster.mongodb.net/chat-users?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI_CHAT=mongodb+srv://username:password@cluster.mongodb.net/chat-messages?retryWrites=true&w=majority&appName=Cluster0

# Redis Configuration
REDIS_URL=redis://localhost:6379
# For production with password: redis://password@hostname:port

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
# For multiple brokers: broker1:9092,broker2:9092

# Redis API Configuration (Upstash, Redis Cloud, or similar)
REDIS_API_URL=https://your-redis-api-endpoint.com
REDIS_API_TOKEN=your_redis_api_token

# Google OAuth Configuration (Get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Service URLs (for development - change for production)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
CHAT_SERVICE_URL=http://localhost:3003
MEDIA_SERVICE_URL=http://localhost:3004

# Frontend URL (change for production)
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development

# Service Ports (change if ports are occupied)
AUTH_PORT=3001
USER_PORT=3002
CHAT_PORT=3003
MEDIA_PORT=3004
GATEWAY_PORT=3000

# Production Additional Variables (uncomment and configure for production)
# REDIS_PASSWORD=your_redis_password
# MONGO_ROOT_USERNAME=your_mongo_username
# MONGO_ROOT_PASSWORD=your_mongo_password
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
